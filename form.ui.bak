  <property name="styleSheet">
   <string notr="true">/* --- ANA GÖVDE: BEYAZ KART VE GÖLGE --- */
QWidget#containerWidget {
    background-color: white;
    border-radius: 15px; /* Köşeleri yuvarlatır */
    border: 1px solid #e0e0e0; /* İnce, açık gri kenarlık */
}

/* --- DİL SEÇİMİ VE BUTONLAR --- */
QComboBox {
    background-color: transparent;
    color: #444;
    border: none;
    font-size: 14px;
    padding: 10px;
}

QPushButton {
    background-color: transparent;
    color: #888;
    border: none;
    font-size: 14px;
    padding: 10px;
}

QPushButton:hover {
    color: #333;
    background-color: #f0f0f0;
    border-radius: 20px;
}

/* --- METİN ALANLARI --- */
QTextEdit, QTextBrowser {
    background-color: transparent;
    color: #333;
    border: none;
    font-size: 15px;
    font-family: &quot;Segoe UI&quot;, sans-serif; /* Pürüzsüz, modern bir font */
    padding: 15px;
}

/* Metin alanları için açık gri kenarlıklar */
QTextEdit {
    border-right: 1px solid #f0f0f0; /* Sol kutuyu ayırmak için */
}

/* Odaklanıldığında minimal bir parıltı */
QTextEdit:focus {
    color: #000;
}</string>
