/* --- SAYFA ARKA PLANI (KOYU TEMA) --- */
QWidget#page_3 {
    background: transparent;
}

/* --- DİL SEÇİM COMBOBOX --- */
QComboBox#inputBox, QComboBox#outputBox {
    background-color: #2b2b3d;
    color: #c0c4d0;
    border: 1.5px solid #3a3a50;
    border-radius: 8px;
    font-size: 14px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-weight: 600;
    padding: 8px 14px;
}

QComboBox#inputBox:hover, QComboBox#outputBox:hover {
    border: 1.5px solid #6c9fff;
    color: #6c9fff;
}

QComboBox#inputBox::drop-down, QComboBox#outputBox::drop-down {
    border: none;
    width: 24px;
    subcontrol-position: center right;
    padding-right: 8px;
}

QComboBox#inputBox::down-arrow, QComboBox#outputBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #a0a4b0;
    margin-right: 6px;
}

QComboBox#inputBox QAbstractItemView, QComboBox#outputBox QAbstractItemView {
    background-color: #2b2b3d;
    color: #c0c4d0;
    border: 1px solid #3a3a50;
    border-radius: 8px;
    padding: 4px;
    selection-background-color: #3a4a6b;
    selection-color: #6c9fff;
}

/* --- SWAP BUTONU --- */
QPushButton#reverseButton {
    background-color: transparent;
    color: #a0a4b0;
    border: none;
    font-size: 18px;
    border-radius: 18px;
}

QPushButton#reverseButton:hover {
    background-color: #3a3a50;
    border-radius: 18px;
}

/* --- GİRİŞ KARTI --- */
QWidget#inputCardWidget {
    background-color: #2b2b3d;
    border-radius: 12px;
    border: 1px solid #3a3a50;
}

/* --- ÇIKIŞ KARTI --- */
QWidget#outputCardWidget {
    background-color: #242436;
    border-radius: 12px;
    border: 1px solid #3a3a50;
}

/* --- METİN ALANLARI --- */
QTextEdit#translateInput {
    background-color: transparent;
    color: #e0e0e0;
    border: none;
    font-size: 16px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    padding: 16px 20px;
}

QTextBrowser#translateOutput {
    background-color: transparent;
    color: #e0e0e0;
    border: none;
    font-size: 16px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    padding: 16px 20px;
}

/* --- SES BUTONLARI --- */
QPushButton#inputVoiceBtn, QPushButton#outputVoiceBtn {
    background-color: transparent;
    color: #8a8e9a;
    border: none;
    font-size: 18px;
    border-radius: 18px;
}

QPushButton#inputVoiceBtn:hover, QPushButton#outputVoiceBtn:hover {
    background-color: #3a3a50;
    border-radius: 18px;
}

/* --- KARAKTER SAYACI --- */
QLabel#charCountLabel {
    color: #6a6e7a;
    font-size: 13px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    background-color: transparent;
    border: none;
}
