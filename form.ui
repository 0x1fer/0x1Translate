/* ====== GLOBAL UYGULAMA STİLİ (KOYU TEMA) ====== */

/* --- ANA PENCERE ARKA PLANI --- */
QMainWindow, QWidget#centralwidget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #1a1a2e, stop:0.5 #16213e, stop:1 #1a1a2e);
}

QStackedWidget {
    background: transparent;
}

/* --- NAVİGASYON BUTONLARI --- */
QPushButton#btnTureng, QPushButton#btnTranslate, QPushButton#btnMyWords {
    background-color: rgba(30, 30, 50, 0.8);
    color: #a0a4b0;
    border: none;
    border-bottom: 3px solid transparent;
    font-size: 14px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-weight: bold;
    padding: 12px 20px;
    border-radius: 0px;
}

QPushButton#btnTureng:hover, QPushButton#btnTranslate:hover, QPushButton#btnMyWords:hover {
    background-color: rgba(40, 40, 65, 0.9);
    color: #6c9fff;
    border-bottom: 3px solid #6c9fff;
    border-radius: 0px;
}

/* --- GENEL METİN ALANLARI --- */
QTextEdit, QTextBrowser {
    background-color: transparent;
    color: #e0e0e0;
    border: none;
    font-size: 15px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    padding: 15px;
}

/* --- GENEL LINE EDIT --- */
QLineEdit {
    background-color: #2b2b3d;
    color: #e0e0e0;
    border: 1px solid #3a3a50;
    border-radius: 8px;
    font-size: 14px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    padding: 8px 16px;
}

QLineEdit:focus {
    border: 2px solid #6c9fff;
}

/* --- GENEL COMBOBOX --- */
QComboBox {
    background-color: transparent;
    color: #a0a4b0;
    border: none;
    font-size: 14px;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    padding: 6px 12px;
}

/* --- GENEL LABEL --- */
QLabel {
    color: #e0e0e0;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    background: transparent;
}

/* --- STATUS BAR --- */
QStatusBar {
    background-color: rgba(20, 20, 35, 0.8);
    color: #a0a4b0;
    font-size: 12px;
    border-top: 1px solid #2a2a40;
}
